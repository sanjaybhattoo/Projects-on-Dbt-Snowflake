# Default environment variables for Airflow

# Airflow Core
AIRFLOW_HOME=/opt/airflow
AIRFLOW__CORE__DAGS_FOLDER=/opt/airflow/dags
AIRFLOW__CORE__EXECUTOR=CeleryExecutor
AIRFLOW__CORE__LOAD_EXAMPLES=False
AIRFLOW__CORE__UNIT_TEST_MODE=False

# Database
AIRFLOW__CORE__SQL_ALCHEMY_CONN=postgresql+psycopg2://airflow:airflow@postgres:5432/airflow

# Celery
AIRFLOW__CELERY__BROKER_URL=redis://redis:6379/0
AIRFLOW__CELERY__RESULT_BACKEND=db+postgresql://airflow:airflow@postgres:5432/airflow

# Snowflake credentials
SNOWFLAKE_ACCOUNT=your_account_id
SNOWFLAKE_USER=your_username
SNOWFLAKE_PASSWORD=your_password
SNOWFLAKE_WAREHOUSE=etl_wh
SNOWFLAKE_DATABASE=analytics_db
SNOWFLAKE_SCHEMA=staging

# Source System
SOURCE_API_ENDPOINT=https://api.example.com
SOURCE_API_KEY=your_api_key
BATCH_SIZE=1000

# Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
FROM_EMAIL=airflow@example.com
ALERT_EMAIL=admin@example.com

# Logging
LOG_LEVEL=INFO
